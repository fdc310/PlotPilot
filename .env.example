# PlotPilot（墨枢）— LLM API 配置
# ═══════════════════════════════════════════════════
# 设置任意一个 API_KEY 即可自动激活对应厂商。
# 未设置时使用 MockProvider（离线/测试模式）。
# 多厂商同时配置时按优先级：Anthropic > OpenAI > Gemini > Ark > 其他国产
# ═══════════════════════════════════════════════════

# ── Anthropic / Claude ──
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=

# ── OpenAI ──
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# ── Google Gemini ──
# GEMINI_API_KEY=
# GEMINI_BASE_URL=
# GEMINI_MODEL=

# ── 豆包 / 火山方舟 Ark ──
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TIMEOUT=120
ARK_REASONING_EFFORT=medium
# ARK_NO_PROXY=1

# ── DeepSeek ──
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# ── MiniMax / 海螺AI（含小米 MiMo）──
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01

# ── SiliconFlow 硅基流动（聚合平台，支持多种开源模型）──
# SILICONFLOW_API_KEY=
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# ── Moonshot / Kimi（月之暗面）──
# MOONSHOT_API_KEY=
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=moonshot-v1-128k

# ── 百度千帆 / 文心一言 ──
# QIANFAN_API_KEY=
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/v2
# QIANFAN_MODEL=ernie-4.0-8k

# ── 零一万物 Yi ──
# YI_API_KEY=
# YI_BASE_URL=https://api.lingyiwanwu.com/v1
# YI_MODEL=yi-large

# ── 强制指定协议（可选）──
# LLM_PROVIDER=openai  # openai / anthropic / gemini

# 可选默认篇幅
# PLOTPILOT_DEFAULT_CHAPTERS=5
# PLOTPILOT_DEFAULT_WORDS_PER_CHAPTER=2500
# PLOTPILOT_SUMMARY_MAX_CHAPTERS=5

# ── Embedding Service Configuration ──
# Mode: 'openai' (cloud, lightweight) or 'local' (requires ~2GB download)
EMBEDDING_SERVICE=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
# Local model path (only used when EMBEDDING_SERVICE=local)
EMBEDDING_MODEL_PATH=./.models/bge-small-zh-v1.5
# GPU acceleration for local model (true/false)
EMBEDDING_USE_GPU=true

# ── Vector Store Configuration ──
VECTOR_STORE_TYPE=chromadb

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/plotpilot.log

# ── 桌面版（Tauri）数据目录 ──
# 生产构建下由 Rust 自动注入，指向用户可写目录（如 Windows: AppData\Roaming\com.plotpilot.desktop\data）
# 本地 CLI / 未设置时仍使用仓库内 data/
# PLOTPILOT_PROD_DATA_DIR=
# （旧名 AITEXT_PROD_DATA_DIR 仍可读，见 application/paths.py）

# 仅 Tauri 开发调试：设为 1 时即使在 debug 构建也注入生产数据目录（便于测 AppData）
# PLOTPILOT_FORCE_PROD_DATA=0

# 开发脚本/离线工具：设为 1 时允许非持久化-consumer 线程直连写 DB（绕过单写者路由）。pytest 通过 conftest 默认开启。
# PLOTPILOT_ALLOW_DIRECT_SQLITE_WRITES=0

# ── 剧情引擎写作路径（Phase 4，默认新管线）──
# 未设置或 writing / 1 / true：StoryPipeline（BaseStoryPipeline 10 步）
# full / engine：同上
# off / legacy / false：legacy 节拍写作（紧急回退）
# PLOTPILOT_USE_STORY_PIPELINE=writing

# 关闭窗口时由 Tauri 调用 POST http://127.0.0.1:<port>/internal/shutdown（仅本机回环），无需手动配置
